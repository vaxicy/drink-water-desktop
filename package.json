{
  "name": "drink-water-desktop",
  "version": "1.0.0",
  "description": "喝水提醒桌面程序",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win"
  },
  "build": {
    "appId": "com.drinkwater.app",
    "productName": "喝水提醒",
    "win": {
      "target": "nsis",
      "icon": "images/icon256.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "installerLanguages": [
        "zh_CN"
      ]
    },
    "files": [
      "app.html",
      "app.js",
      "main.js",
      "preload.js",
      "images/**"
    ]
  },
  "devDependencies": {
    "electron": "^29.0.0",
    "electron-builder": "^24.0.0"
  }
}